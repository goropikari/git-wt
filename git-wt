#!/usr/bin/env bash

set -euo pipefail

REPO_OWNER="${REPO_OWNER:-goropikari}"
REPO_NAME="${REPO_NAME:-git-wt}"
REPO_REF="${REPO_REF:-main}"
RAW_BASE_URL="${RAW_BASE_URL:-https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_REF}}"

progress_enabled=0

cleanup_files=()

# Remove temporary files and directories created while evaluating
# .worktreeinclude and detecting the new worktree path.
cleanup() {
	local path
	for path in "${cleanup_files[@]}"; do
		[[ -n "$path" && -e "$path" ]] && rm -rf -- "$path"
	done
	return 0
}

trap cleanup EXIT

# Bash passes strings around, so these helpers assign mktemp output to
# a caller-provided variable name.
make_temp_file() {
	local output_name="$1"
	local path
	path="$(mktemp)"
	cleanup_files+=("$path")
	printf -v "$output_name" '%s' "$path"
}

make_temp_dir() {
	local output_name="$1"
	local path
	path="$(mktemp -d)"
	cleanup_files+=("$path")
	printf -v "$output_name" '%s' "$path"
}

emit_progress() {
	local current="$1"
	local total="$2"
	local rel_path="$3"

	if [[ "$progress_enabled" -eq 1 ]]; then
		printf '\r[%d/%d] %s' "$current" "$total" "$rel_path" >&2
	fi
}

finish_progress() {
	if [[ "$progress_enabled" -eq 1 ]]; then
		printf '\n' >&2
	fi
}

has_command() {
	command -v "$1" >/dev/null 2>&1
}

print_help() {
	cat <<'EOF'
usage: git wt <subcommand> [args...]

Git plugin for git worktree.

subcommands:
  add       run git worktree add, then copy .worktreeinclude matches
  remove    remove a worktree by path or branch name
  update    replace this script with the latest downloaded git-wt
  help      show this help
  *         any other subcommand is passed through to git worktree

.worktreeinclude:
  - must be placed at the repository root
  - uses .gitignore syntax
  - only ignored paths are copied
EOF
}

need_command() {
	local command_name="$1"
	if ! has_command "$command_name"; then
		printf 'missing required command: %s\n' "$command_name" >&2
		return 1
	fi
}

download_file() {
	local source_url="$1"
	local destination_path="$2"

	curl -fsSL "$source_url" -o "$destination_path"
}

resolve_script_path() {
	local script_path="${BASH_SOURCE[0]}"

	if [[ "$script_path" != */* ]]; then
		script_path="$(command -v -- "$script_path")"
	fi

	readlink -f -- "$script_path"
}

# Parse `git worktree list --porcelain` and keep only the actual
# filesystem paths of each worktree.
list_worktrees() {
	git worktree list --porcelain | while IFS= read -r line; do
		if [[ "$line" == worktree\ * ]]; then
			printf '%s\n' "${line#worktree }"
		fi
	done
}

find_worktree_by_branch() {
	local branch_name="$1"
	local line
	local current_path=''
	local current_branch=''
	local -a matches=()

	while IFS= read -r line; do
		if [[ -z "$line" ]]; then
			if [[ "$current_branch" == "refs/heads/$branch_name" ]]; then
				matches+=("$current_path")
			fi
			current_path=''
			current_branch=''
			continue
		fi

		case "$line" in
		worktree\ *)
			current_path="${line#worktree }"
			;;
		branch\ *)
			current_branch="${line#branch }"
			;;
		esac
	done < <(git worktree list --porcelain)

	if [[ -n "$current_path" && "$current_branch" == "refs/heads/$branch_name" ]]; then
		matches+=("$current_path")
	fi

	if [[ "${#matches[@]}" -eq 1 ]]; then
		printf '%s\n' "${matches[0]}"
		return 0
	fi

	if [[ "${#matches[@]}" -eq 0 ]]; then
		printf 'no worktree found for branch: %s\n' "$branch_name" >&2
		return 1
	fi

	printf 'multiple worktrees found for branch: %s\n' "$branch_name" >&2
	return 1
}

is_worktree_path() {
	local candidate="$1"
	local path

	while IFS= read -r path; do
		if [[ "$path" == "$candidate" ]]; then
			return 0
		fi
	done < <(list_worktrees)

	return 1
}

# `git worktree add` accepts many argument forms. Instead of parsing
# argv ourselves, compare worktree lists before and after execution
# and pick the single newly added path.
detect_new_worktree() {
	local before_file="$1"
	local after_file="$2"
	local path
	local -A before=()
	local -a new_paths=()

	while IFS= read -r path; do
		[[ -n "$path" ]] || continue
		before["$path"]=1
	done <"$before_file"

	while IFS= read -r path; do
		[[ -n "$path" ]] || continue
		if [[ -z "${before[$path]+x}" ]]; then
			new_paths+=("$path")
		fi
	done <"$after_file"

	if [[ "${#new_paths[@]}" -ne 1 ]]; then
		printf 'failed to determine the new worktree path\n' >&2
		return 1
	fi

	printf '%s\n' "${new_paths[0]}"
}

# Enumerate every path in the source worktree except `.git`, keeping
# paths relative to the repository root so they can be copied as-is
# into the destination worktree.
collect_repo_entries() {
	local repo_root="$1"
	local entries_name="$2"
	local rel_path

	eval "$entries_name=()"
	while IFS= read -r -d '' rel_path; do
		eval "$entries_name+=(\"\$rel_path\")"
	done < <(
		cd "$repo_root" &&
			find . \
				\( -path './.git' -o -path './.git/*' \) -prune -o \
				-mindepth 1 -printf '%P\0' |
			LC_ALL=C sort -z
	)
}

# Ask Git which paths are ignored.
# - "standard" mode uses the real repository ignore rules.
# - "include" mode evaluates `.worktreeinclude` in an isolated temp repo
#   so only that file's patterns participate in the match result.
# The intersection of these two sets becomes the copy target list.
build_ignore_match_set() {
	local repo_root="$1"
	local include_file="$2"
	local mode="$3"
	local entries_name="$4"
	local output_name="$5"
	local entry
	local match_path
	local _source line _pattern path
	local temp_repo
	local -n entries_ref="$entries_name"

	eval "$output_name=()"

	if [[ "${#entries_ref[@]}" -eq 0 ]]; then
		return 0
	fi

	if [[ "$mode" == "standard" ]]; then
		while IFS= read -r -d '' _source &&
			IFS= read -r -d '' line &&
			IFS= read -r -d '' _pattern &&
			IFS= read -r -d '' path; do
			path="${path%/}"
			eval "${output_name}[\"\$path\"]=1"
		done < <(
			{
				for entry in "${entries_ref[@]}"; do
					match_path="$entry"
					if [[ -d "$repo_root/$entry" && ! -L "$repo_root/$entry" ]]; then
						match_path="$entry/"
					fi
					printf '%s\0' "$match_path"
				done |
					git -C "$repo_root" check-ignore --stdin -z -v --no-index
			} || true
		)
		return 0
	fi

	make_temp_dir temp_repo
	git init -q "$temp_repo"
	cp -- "$include_file" "$temp_repo/.gitignore"

	while IFS= read -r -d '' _source &&
		IFS= read -r -d '' line &&
		IFS= read -r -d '' _pattern &&
		IFS= read -r -d '' path; do
		path="${path%/}"
		eval "${output_name}[\"\$path\"]=1"
	done < <(
		{
			for entry in "${entries_ref[@]}"; do
				match_path="$entry"
				if [[ -d "$repo_root/$entry" && ! -L "$repo_root/$entry" ]]; then
					match_path="$entry/"
				fi
				printf '%s\0' "$match_path"
			done |
				git -C "$temp_repo" check-ignore --stdin -z -v --no-index
		} || true
	)
}

collect_copy_targets() {
	local repo_root="$1"
	local include_file="$2"
	local output_name="$3"
	local entry
	local -a entries=()
	local -A ignored_matches=()
	local -A include_matches=()

	collect_repo_entries "$repo_root" entries
	build_ignore_match_set "$repo_root" "$include_file" standard entries ignored_matches
	build_ignore_match_set "$repo_root" "$include_file" include entries include_matches

	eval "$output_name=()"
	for entry in "${entries[@]}"; do
		if [[ "$entry" == ".worktreeinclude" ]]; then
			continue
		fi
		if [[ -n "${ignored_matches[$entry]+x}" && -n "${include_matches[$entry]+x}" ]]; then
			eval "$output_name+=(\"\$entry\")"
		fi
	done
}

# Recreate a single relative path inside the new worktree.
# Existing destinations are preserved and reported as skipped.
copy_target() {
	local repo_root="$1"
	local destination_root="$2"
	local rel_path="$3"
	local source_path="$repo_root/$rel_path"
	local destination_path="$destination_root/$rel_path"
	local parent_dir
	local link_target

	if [[ -L "$source_path" ]]; then
		parent_dir="$(dirname -- "$destination_path")"
		if ! mkdir -p -- "$parent_dir"; then
			printf 'failed to create parent directory for %s\n' "$rel_path" >&2
			return 1
		fi
		if [[ -e "$destination_path" || -L "$destination_path" ]]; then
			printf 'skipped existing path: %s\n' "$rel_path" >&2
			return 0
		fi
		link_target="$(readlink -- "$source_path")"
		if ! ln -s -- "$link_target" "$destination_path"; then
			printf 'failed to copy symlink: %s\n' "$rel_path" >&2
			return 1
		fi
		return 0
	fi

	if [[ -d "$source_path" ]]; then
		if [[ -e "$destination_path" && ! -d "$destination_path" ]]; then
			printf 'destination exists and is not a directory: %s\n' "$rel_path" >&2
			return 1
		fi
		mkdir -p -- "$destination_path"
		return 0
	fi

	if [[ -f "$source_path" ]]; then
		parent_dir="$(dirname -- "$destination_path")"
		if ! mkdir -p -- "$parent_dir"; then
			printf 'failed to create parent directory for %s\n' "$rel_path" >&2
			return 1
		fi
		if [[ -e "$destination_path" || -L "$destination_path" ]]; then
			printf 'skipped existing path: %s\n' "$rel_path" >&2
			return 0
		fi
		if ! cp -p -- "$source_path" "$destination_path"; then
			printf 'failed to copy file: %s\n' "$rel_path" >&2
			return 1
		fi
		return 0
	fi

	printf 'unsupported path type: %s\n' "$rel_path" >&2
	return 1
}

copy_targets_fallback() {
	local repo_root="$1"
	local destination_root="$2"
	local targets_name="$3"
	local rel_path
	local failed=0
	local index=0
	local -n targets_ref="$targets_name"

	for rel_path in "${targets_ref[@]}"; do
		index=$((index + 1))
		emit_progress "$index" "${#targets_ref[@]}" "$rel_path"
		if ! copy_target "$repo_root" "$destination_root" "$rel_path"; then
			failed=$((failed + 1))
		fi
	done

	finish_progress

	if [[ "$failed" -gt 0 ]]; then
		printf 'worktree was created at %s, but copying ignored files failed for %d path(s)\n' \
			"$destination_root" "$failed" >&2
		return 1
	fi

	return 0
}

copy_targets_with_rsync() {
	local repo_root="$1"
	local destination_root="$2"
	local targets_name="$3"
	local list_file
	local rel_path
	local index=0
	local total=0
	local -n targets_ref="$targets_name"

	make_temp_file list_file
	total="${#targets_ref[@]}"

	for rel_path in "${targets_ref[@]}"; do
		printf '%s\0' "$rel_path" >>"$list_file"
	done

	if ! (
		cd "$repo_root"
		rsync -a --ignore-existing --from0 --files-from="$list_file" \
			--out-format='%n' ./ "$destination_root"/
	) | while IFS= read -r rel_path; do
		if [[ "$progress_enabled" -eq 1 ]]; then
			index=$((index + 1))
			emit_progress "$index" "$total" "$rel_path"
		fi
	done; then
		finish_progress
		printf 'worktree was created at %s, but bulk copy with rsync failed\n' \
			"$destination_root" >&2
		return 1
	fi

	finish_progress
	return 0
}

copy_targets() {
	local repo_root="$1"
	local destination_root="$2"
	local targets_name="$3"

	if has_command rsync; then
		copy_targets_with_rsync "$repo_root" "$destination_root" "$targets_name"
		return $?
	fi

	copy_targets_fallback "$repo_root" "$destination_root" "$targets_name"
}

# `git wt add` is the only subcommand with custom behavior:
# 1. delegate to `git worktree add`
# 2. discover the newly created worktree
# 3. compute ignored paths that also match `.worktreeinclude`
# 4. copy them into the new worktree
handle_add() {
	local repo_root
	local include_file
	local before_file
	local after_file
	local new_worktree
	local total=0
	local -a targets=()

	repo_root="$(git rev-parse --show-toplevel)"
	include_file="$repo_root/.worktreeinclude"
	make_temp_file before_file
	make_temp_file after_file

	list_worktrees >"$before_file"

	if ! git worktree add "$@"; then
		return $?
	fi

	list_worktrees >"$after_file"
	new_worktree="$(detect_new_worktree "$before_file" "$after_file")"

	if [[ ! -f "$include_file" ]]; then
		return 0
	fi

	include_file="$(readlink -f -- "$include_file")"
	collect_copy_targets "$repo_root" "$include_file" targets

	total="${#targets[@]}"
	if [[ "$total" -eq 0 ]]; then
		return 0
	fi

	if [[ -t 2 ]]; then
		progress_enabled=1
	fi

	copy_targets "$repo_root" "$new_worktree" targets
}

handle_remove() {
	local target
	local resolved_path
	local -a args=()

	if [[ "$#" -eq 0 ]]; then
		exec git worktree remove
	fi

	args=("$@")
	target="${args[$(($# - 1))]}"

	if [[ -e "$target" || -L "$target" ]]; then
		if is_worktree_path "$target"; then
			exec git worktree remove "${args[@]}"
		fi
	fi

	resolved_path="$(find_worktree_by_branch "$target")" || return $?
	args[$# - 1]="$resolved_path"
	exec git worktree remove "${args[@]}"
}

handle_update() {
	local script_path
	local script_dir
	local temp_script

	need_command curl

	script_path="$(resolve_script_path)"
	script_dir="$(dirname -- "$script_path")"
	temp_script="$(mktemp "$script_dir/.git-wt.update.XXXXXX")"
	cleanup_files+=("$temp_script")

	download_file "$RAW_BASE_URL/git-wt" "$temp_script"
	chmod 0755 "$temp_script"
	mv -- "$temp_script" "$script_path"

	printf 'updated git-wt at %s\n' "$script_path"
}

main() {
	local subcommand

	if [[ "$#" -eq 0 ]]; then
		exec git worktree
	fi

	subcommand="$1"
	shift

	case "$subcommand" in
	help | --help | -h)
		print_help
		;;
	add)
		handle_add "$@"
		;;
	remove)
		handle_remove "$@"
		;;
	update)
		handle_update "$@"
		;;
	*)
		exec git worktree "$subcommand" "$@"
		;;
	esac
}

main "$@"
